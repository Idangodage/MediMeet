{
  "expo": {
    "name": "MediMeet",
    "slug": "medimeet",
    "scheme": "medimeet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6FAF9"
      }
    }
  }
}
