{
  "expo": {
    "name": "MediMeet",
    "slug": "medimeet",
    "scheme": "medimeet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "ios": {
      "bundleIdentifier": "com.medimeet.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.medimeet.app",
      "adaptiveIcon": {
        "backgroundColor": "#F7FAFC"
      },
      "permissions": []
    },
    "extra": {
      "appEnv": "development"
    }
  }
}
